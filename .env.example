# Copie para .env e preencha. O .env é gitignored — nunca comite credenciais.

# Neon (Postgres + pgvector) — connection string do seu projeto.
# Crie em https://neon.tech (free tier) e habilite a extensão `vector`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Anthropic — chave da API, usada pelo Claude Agent SDK.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Jina AI — embeddings (e rerank). https://jina.ai
JINA_API_KEY=jina_...

# --- opcionais ---
# PORT=3001          # porta do servidor web (Vite roda na 5173 e faz proxy)
# LOG_DIR=logs       # diretório dos logs (app.jsonl + app.log)
# CHAT_DB=data/chat.db   # caminho do SQLite das conversas
